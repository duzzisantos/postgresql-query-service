LOCALHOST=0.0.0.0
PORT=8000
WEBHOST=

POSTGRES_URL=postgresql://user:password@localhost:5432/mydb

REDIS_CLIENT_URL=localhost
REDIS_PORT=6379
REDIS_DECODE_RESPONSES=True

# Auth — leave blank to disable API key requirement (dev mode)
API_KEY=
CSRF_SECRET=

# SMTP — plug in any provider (Gmail, Outlook, SES, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
